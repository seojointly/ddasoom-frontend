# Vite 환경 변수 예시 파일 (키 목록만 커밋). 실제 값은 .env.local 에 작성 — .gitignore 대상.
# VITE_ 접두사가 붙은 변수만 클라이언트 번들에 노출됩니다(import.meta.env.VITE_...).
# 비밀값(SMTP 계정, 공공 API 키 등)은 전부 백엔드 전용이므로 이 파일에 넣지 않습니다.

# API 기본 경로. 프록시 사용 시 /api 고정 (예시: /api)
VITE_API_BASE_URL=

# Vite 프록시가 전달할 백엔드 주소 (vite.config에서만 사용, 예시: http://localhost:8080)
VITE_API_PROXY_TARGET=

# 카카오 OAuth 클라이언트 ID (SNS 로그인 착수 시 발급)
VITE_KAKAO_CLIENT_ID=
